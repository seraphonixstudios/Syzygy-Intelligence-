# ──────────────────────────────────────────────────────────────────────
# Syzygy Intelligence Configuration
# ──────────────────────────────────────────────────────────────────────
# Copy this file to .env and configure for your environment.
# NEVER commit .env to version control!

# ──── Environment ────────────────────────────────────────────────────
# Options: development, production, testing
SYZYGY_ENV=development

# ──── Logging ────────────────────────────────────────────────────────
SYZYGY_LOG_LEVEL=INFO
SYZYGY_LOG_FORMAT=json

# ──── Security ───────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SYZYGY_SECRET_KEY=change-me-to-a-random-secret

# ──── CORS Origins ───────────────────────────────────────────────────
# Comma-separated list of allowed origins
SYZYGY_CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ──── Database (PostgreSQL) ──────────────────────────────────────────
# Option 1: Use DATABASE_URL (takes precedence)
# DATABASE_URL=postgresql://syzygy:syzygy_secret@postgres:5432/syzygy

# Option 2: Individual settings
SYZYGY_DB_HOST=postgres
SYZYGY_DB_PORT=5432
SYZYGY_DB_NAME=syzygy
SYZYGY_DB_USER=syzygy
SYZYGY_DB_PASSWORD=syzygy_secret

# Docker Compose overrides (for cross-container communication)
SYZYGY_DB_HOST_DOCKER=postgres

# ──── Redis ──────────────────────────────────────────────────────────
SYZYGY_REDIS_URL=redis://redis:6379/0
SYZYGY_REDIS_URL_DOCKER=redis://redis:6379/0
REDIS_PASSWORD=

# ──── Neo4j ──────────────────────────────────────────────────────────
SYZYGY_NEO4J_URI=bolt://neo4j:7687
SYZYGY_NEO4J_URI_DOCKER=bolt://neo4j:7687
SYZYGY_NEO4J_USER=neo4j
SYZYGY_NEO4J_PASSWORD=syzygy_secret

# ──── OAuth Providers ────────────────────────────────────────────────
SYZYGY_GOOGLE_CLIENT_ID=
SYZYGY_GOOGLE_CLIENT_SECRET=
SYZYGY_GITHUB_CLIENT_ID=
SYZYGY_GITHUB_CLIENT_SECRET=
SYZYGY_OAUTH_REDIRECT_URL=http://localhost:8000/api/auth/oauth

# ──── LLM Configuration ──────────────────────────────────────────────
# Ollama
SYZYGY_OLLAMA_BASE_URL=http://ollama:11434
SYZYGY_OLLAMA_BASE_URL_DOCKER=http://ollama:11434
SYZYGY_DEFAULT_MODEL=qwen3:8b-gpu
SYZYGY_CRITIC_MODEL=qwen3:8b-gpu
SYZYGY_SYNTHESIS_MODEL=qwen3:8b-gpu
SYZYGY_CODING_MODEL=qwen3:8b-gpu
SYZYGY_CREATIVE_MODEL=qwen3:8b-gpu
SYZYGY_VISION_MODEL=llava:13b-gpu
SYZYGY_GPU_MODEL=qwen3:8b-gpu
SYZYGY_FAST_MODEL=qwen3:8b-gpu

# LiteLLM Fallback
SYZYGY_LITELLM_ENABLED=false
SYZYGY_OPENAI_API_KEY=
SYZYGY_ANTHROPIC_API_KEY=
SYZYGY_FALLBACK_MODEL=gpt-4o-mini

# ──── Consensus Engine ──────────────────────────────────────────────
SYZYGY_MAX_CONSENSUS_ROUNDS=6
SYZYGY_MIN_CONSENSUS_ROUNDS=2
SYZYGY_CONVERGENCE_THRESHOLD=0.85
SYZYGY_VARIANCE_THRESHOLD=0.1

# ──── Sandbox Execution ──────────────────────────────────────────────
SYZYGY_SANDBOX_TIMEOUT=120
SYZYGY_SANDBOX_MEMORY_LIMIT=512m

# ──── File Uploads ───────────────────────────────────────────────────
SYZYGY_MAX_UPLOAD_SIZE_MB=10

# ──── Email Configuration ────────────────────────────────────────────
# Provider: console (development), sendgrid, ses
SYZYGY_EMAIL_PROVIDER=console
SYZYGY_EMAIL_FROM_ADDRESS=noreply@syzygy.local
SYZYGY_EMAIL_FROM_NAME=Syzygy Intelligence

# SendGrid
SYZYGY_SENDGRID_API_KEY=

# AWS SES
SYZYGY_SES_REGION=us-east-1
SYZYGY_SES_ACCESS_KEY_ID=
SYZYGY_SES_SECRET_ACCESS_KEY=

# ──── Rate Limiting ──────────────────────────────────────────────────
SYZYGY_RATE_LIMIT_ENABLED=true
SYZYGY_RATE_LIMIT_PER_SECOND=10.0
SYZYGY_RATE_LIMIT_BURST=20
SYZYGY_RATE_LIMIT_AUTHENTICATED_PER_SECOND=30.0
SYZYGY_RATE_LIMIT_AUTHENTICATED_BURST=60

# ──── Stripe (Payments) ──────────────────────────────────────────────
SYZYGY_STRIPE_SECRET_KEY=
SYZYGY_STRIPE_PUBLISHABLE_KEY=
SYZYGY_STRIPE_WEBHOOK_SECRET=
SYZYGY_STRIPE_PREMIUM_PRICE_ID=price_premium_monthly
SYZYGY_STRIPE_ENTERPRISE_PRICE_ID=price_enterprise_monthly

# ──── Billing ────────────────────────────────────────────────────────
SYZYGY_FREE_TIER_DAYS=14
SYZYGY_FREE_TIER_MONTHLY_MESSAGES=100
SYZYGY_PREMIUM_MONTHLY_MESSAGES=10000

# ──── Monitoring / Observability ────────────────────────────────────
# Jaeger tracing (production only by default)
SYZYGY_JAEGER_HOST=jaeger
SYZYGY_JAEGER_PORT=6831

# Grafana admin password (set in .env, not .env.example)
# GRAFANA_PASSWORD=admin

# ──── Frontend (Next.js Public) ──────────────────────────────────────
NEXT_PUBLIC_SYZYGY_API_URL=http://localhost:8000
NEXT_PUBLIC_SYZYGY_WS_URL=ws://localhost:8000/ws
