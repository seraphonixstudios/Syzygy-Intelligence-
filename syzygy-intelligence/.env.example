# Syzygy Intelligence Configuration
# Copy this file to .env and customize for your environment
#
# PRODUCTION DEPLOYMENT:
# 1. Generate SYZYGY_SECRET_KEY: openssl rand -hex 32
# 2. Set SYZYGY_ENV=production
# 3. Configure SYZYGY_CORS_ORIGINS for your domain
# 4. Set all database passwords to secure values
# 5. Use environment overrides for Docker container networking

# --- General ---
SYZYGY_ENV=development
SYZYGY_LOG_LEVEL=INFO
# SECURITY: Generate a random secret for production: openssl rand -hex 32
SYZYGY_SECRET_KEY=change-me-to-a-random-secret
# Comma-separated list of allowed CORS origins
SYZYGY_CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# --- Database ---
SYZYGY_DB_HOST=localhost
SYZYGY_DB_PORT=5432
SYZYGY_DB_NAME=syzygy
SYZYGY_DB_USER=syzygy
SYZYGY_DB_PASSWORD=syzygy_secret

# --- Redis ---
SYZYGY_REDIS_URL=redis://localhost:6379/0

# --- Neo4j ---
SYZYGY_NEO4J_URI=bolt://localhost:7687
SYZYGY_NEO4J_USER=neo4j
SYZYGY_NEO4J_PASSWORD=syzygy_secret

# --- Chroma ---
SYZYGY_CHROMA_PATH=./data/chroma

# --- Models (Ollama) ---
# See scripts/setup-ollama.ps1 for automated setup
# These model names are custom tags. To create them after pulling the base model:
#   ollama pull qwen2.5:7b && ollama cp qwen2.5:7b qwen3:8b-gpu
# Or set alternatives below (uncomment and adjust)
SYZYGY_OLLAMA_BASE_URL=http://localhost:11434
SYZYGY_DEFAULT_MODEL=qwen3:8b-gpu
SYZYGY_CRITIC_MODEL=qwen3:8b-gpu
SYZYGY_SYNTHESIS_MODEL=qwen3:8b-gpu
SYZYGY_CODING_MODEL=qwen3:8b-gpu
SYZYGY_CREATIVE_MODEL=dolphin-llama3:8b-gpu
SYZYGY_VISION_MODEL=llava:13b-gpu
SYZYGY_GPU_MODEL=qwen3:8b-gpu
SYZYGY_FAST_MODEL=dolphin-llama3:8b-gpu
# Alternative — CPU-friendly defaults (uncomment to use):
# SYZYGY_DEFAULT_MODEL=qwen2.5:7b
# SYZYGY_CREATIVE_MODEL=llama3.2:3b
# SYZYGY_VISION_MODEL=llava:7b
# SYZYGY_FAST_MODEL=llama3.2:3b

# --- LiteLLM Fallback (optional) ---
SYZYGY_LITELLM_ENABLED=false
SYZYGY_OPENAI_API_KEY=
SYZYGY_ANTHROPIC_API_KEY=
SYZYGY_FALLBACK_MODEL=gpt-4o-mini

# --- Consensus Engine ---
SYZYGY_MAX_CONSENSUS_ROUNDS=6
SYZYGY_MIN_CONSENSUS_ROUNDS=2
SYZYGY_CONVERGENCE_THRESHOLD=0.85
SYZYGY_VARIANCE_THRESHOLD=0.1

# --- Execution ---
SYZYGY_SANDBOX_DOCKER_IMAGE=syzygy-sandbox:latest
SYZYGY_SANDBOX_TIMEOUT=120
SYZYGY_SANDBOX_MEMORY_LIMIT=512m

# --- Frontend (Next.js public environment variables) ---
NEXT_PUBLIC_SYZYGY_API_URL=http://localhost:8000
NEXT_PUBLIC_SYZYGY_WS_URL=ws://localhost:8000/ws

# --- OAuth (Google & GitHub) ---
# To enable Google login:
#   1. Go to https://console.cloud.google.com/apis/credentials
#   2. Create OAuth 2.0 Client ID (Web application)
#   3. Add Authorized Redirect URI: http://localhost:8000/api/auth/oauth/google/callback
#   4. Set the credentials below
# SYZYGY_GOOGLE_CLIENT_ID=
# SYZYGY_GOOGLE_CLIENT_SECRET=
#
# To enable GitHub login:
#   1. Go to https://github.com/settings/developers
#   2. Create OAuth App
#   3. Add Authorization callback URL: http://localhost:8000/api/auth/oauth/github/callback
#   4. Set the credentials below
# SYZYGY_GITHUB_CLIENT_ID=
# SYZYGY_GITHUB_CLIENT_SECRET=
# Note: If port 8000 is unavailable, update to match your backend port (e.g., :8001)
SYZYGY_OAUTH_REDIRECT_URL=http://localhost:8000/api/auth/oauth

# --- Stripe (optional) ---
# SYZYGY_STRIPE_SECRET_KEY=
# SYZYGY_STRIPE_PUBLISHABLE_KEY=
# SYZYGY_STRIPE_WEBHOOK_SECRET=
